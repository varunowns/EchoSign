# =============================================================================
# EchoSign — Environment Variable Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is gitignored — it will never be committed.
# =============================================================================

# ── Backend ──────────────────────────────────────────────────────────────────
# Host and port the FastAPI / WebSocket server binds to.
# Defaults used when unset: 0.0.0.0 and 8000
HOST=0.0.0.0
PORT=8000

# ── Frontend ─────────────────────────────────────────────────────────────────
# Backend URL that the Next.js frontend connects to.
# Used in frontend/.env.local — keep these two in sync.
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. "*" allows all (dev only).
# In production, set to e.g. https://echosign.example.com
CORS_ORIGINS=*

# ── Model Paths (optional overrides) ─────────────────────────────────────────
# If unset, the backend resolves these relative to the backend/ directory.
# MEDIAPIPE_HAND_MODEL=hand_landmarker.task
# MEDIAPIPE_POSE_MODEL=pose_landmarker.task
# M2_MODEL_PATH=models/asl_alphabet.pkl
# M4_MODEL_PATH=models/asl_sequence.pt

# ── ML Pipeline Tuning (optional overrides) ──────────────────────────────────
# CONFIG_IDENTIFIER=production
# CONFIDENCE_THRESHOLD=0.15
# COOLDOWN_FRAMES=30
